# Stripe — get these from dashboard.stripe.com (use sk_test_... for local testing)
STRIPE_SECRET_KEY=

# Turso — hosted SQLite for persistent user progress
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Resend — transactional email for magic links
RESEND_API_KEY=

# Auth — generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=
FROM_EMAIL=noreply@playhacklab.com

# Dev flags
DEV_UNLOCK=1
EXTRA_LEVELS=1
